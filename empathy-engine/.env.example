# Empathy Engine — Environment Variables
# Copy this file to .env and fill in values as needed.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── ElevenLabs (Optional — for high-quality cloud TTS) ───────────────────────
# If set, the engine will prefer ElevenLabs over pyttsx3.
# Leave blank to use the offline pyttsx3 engine (default).
ELEVENLABS_API_KEY=

# ── HuggingFace (Optional) ────────────────────────────────────────────────────
# Set to a local directory to load the model offline without downloading.
# Leave blank to auto-download from HuggingFace Hub on first run.
HF_MODEL_CACHE=
